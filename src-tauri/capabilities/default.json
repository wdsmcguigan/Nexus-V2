{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl-manifests/core/schema.json",
  "identifier": "default",
  "description": "Default permissions for Nexus",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-create",
    "fs:allow-remove",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "core:window:allow-set-title"
  ]
}
