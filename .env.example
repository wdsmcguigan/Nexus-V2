# Gmail OAuth credentials
# Create these at console.cloud.google.com → APIs & Services → Credentials
# Application type: Desktop app
NEXUS_GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
NEXUS_GMAIL_CLIENT_SECRET=your-client-secret

# Microsoft / Outlook OAuth credentials (EP6)
# Register an app at portal.azure.com → App registrations
# Add delegated permissions: IMAP.AccessAsUser.All, SMTP.Send, offline_access
# Add http://localhost as a redirect URI (Mobile and desktop applications)
NEXUS_OUTLOOK_CLIENT_ID=your-azure-app-id
NEXUS_OUTLOOK_CLIENT_SECRET=your-azure-client-secret
